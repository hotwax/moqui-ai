<?xml version="1.0" encoding="UTF-8"?>
<!-- v1 authorization for the AI Ops console: grant all authenticated users (ALL_USERS) view+action
     access to the moqui-ai screens + their transitions. Mirrors the built-in ALL_USERS -> ALL_SCREENS
     grant. This ALL_USERS grant governs only whether the screens/services are INVOKABLE.

     The two MUTATING cross-user paths are scoped per-record IN-SERVICE (an inline owner-OR-AI_OPERATOR guard),
     not by this coarse grant: AgentServices.run#Conversation (driving a thread) and
     ToolCallRequestServices.decide#ToolCallRequest (approving/rejecting a gated tool call) require the caller to
     OWN the conversation or hold AI_OPERATOR / ADMIN. Read aggregates (WorkforceServices) stay company-wide by
     the 2026-06-11 product decision. The AI_OPERATOR group below is declared so deployments can grant it; no
     members are seeded here (deployment-specific — grant it to the staff who run the cross-user Ai Ops queue). -->
<entity-facade-xml type="install">
    <!-- Dedicated operator role for cross-user AI actions (owner-OR-operator gate). Declared, not populated:
         grant membership per deployment via moqui.security.UserGroupMember. ADMIN is also honored by the gate. -->
    <moqui.security.UserGroup userGroupId="AI_OPERATOR" description="AI Operator (may drive/approve any user's AI conversation)"/>

    <moqui.security.ArtifactGroup artifactGroupId="AI_OPS_SCREENS" description="AI Ops console screens + transitions"/>
    <moqui.security.ArtifactGroupMember artifactGroupId="AI_OPS_SCREENS"
        artifactName="component://moqui-ai/screen/.*" artifactTypeEnumId="AT_XML_SCREEN" nameIsPattern="Y"/>
    <moqui.security.ArtifactGroupMember artifactGroupId="AI_OPS_SCREENS"
        artifactName="component://moqui-ai/screen/.*" artifactTypeEnumId="AT_XML_SCREEN_TRANS" nameIsPattern="Y"/>
    <!-- entity reads/writes used by the screens + the agent loop (moqui.ai.*) -->
    <moqui.security.ArtifactGroupMember artifactGroupId="AI_OPS_SCREENS"
        artifactName="moqui\.ai\..*" artifactTypeEnumId="AT_ENTITY" nameIsPattern="Y"/>
    <!-- status lifecycle reads: entity-auto update# of any AI entity with a statusId change validates the
         transition by reading moqui.basic.StatusFlowTransition / StatusItem (EntityAutoServiceRunner.checkStatus).
         AI status changes happen via authenticate services (run#Agent suspend/complete, activate#Agent draft->active),
         so a logged-in operator needs read access to these or the transition check is denied. -->
    <moqui.security.ArtifactGroupMember artifactGroupId="AI_OPS_SCREENS"
        artifactName="moqui\.basic\.Status.*" artifactTypeEnumId="AT_ENTITY" nameIsPattern="Y"/>
    <!-- form-list rendering reads per-user column config (moqui.screen.form.FormConfigUser, FormConfig, ...).
         Without this member a non-admin operator hits "not authorized for View on Entity FormConfigUser"
         and EVERY form-list on the AI Ops screens (including the Composer conversation) fails to render. -->
    <moqui.security.ArtifactGroupMember artifactGroupId="AI_OPS_SCREENS"
        artifactName="moqui\.screen\.form\..*" artifactTypeEnumId="AT_ENTITY" nameIsPattern="Y"/>
    <!-- AI services invoked from the screens (run#Agent, approvals, cost) + the NotNaked OMS tool/runner -->
    <moqui.security.ArtifactGroupMember artifactGroupId="AI_OPS_SCREENS"
        artifactName="ai\..*" artifactTypeEnumId="AT_SERVICE" nameIsPattern="Y"/>
    <moqui.security.ArtifactGroupMember artifactGroupId="AI_OPS_SCREENS"
        artifactName="notnaked\.OmsAiServices\..*" artifactTypeEnumId="AT_SERVICE" nameIsPattern="Y"/>
    <!-- Service REST facade (service/ai.rest.xml): the /ai root resource itself must be authorized
         for the path check in RestApi.run; the services/entities it calls are members above. -->
    <moqui.security.ArtifactGroupMember artifactGroupId="AI_OPS_SCREENS"
        artifactName="/ai" artifactTypeEnumId="AT_REST_PATH" inheritAuthz="Y"/>
    <!-- ALLOW all actions to every authenticated user. NOTE: in this framework version ArtifactAuthz has no
         inheritAuthz column, so authz does NOT auto-cascade to nested artifacts — each entity/service the
         screens touch must be listed as a group member above (moqui.ai.*, ai.*, moqui.basic.Status.*,
         moqui.screen.form.*, notnaked.OmsAiServices.*). -->
    <moqui.security.ArtifactAuthz artifactAuthzId="AI_OPS_ALL_USERS" userGroupId="ALL_USERS"
        artifactGroupId="AI_OPS_SCREENS" authzTypeEnumId="AUTHZT_ALLOW" authzActionEnumId="AUTHZA_ALL"/>

    <!-- Read-only access to the business data the seeded agent tools summarize. A SEPARATE, VIEW-only group
         so it does NOT inherit the all-actions grant above. An agent runs AS the signed-in user, so that
         user needs read access to what its tools read, or the tool is denied — e.g. the NotNaked order
         tool (notnaked.OmsAiServices.get#OrderSummaryList) reads org.apache.ofbiz.order.*.
         NOTE: v1 grants ALL_USERS for the demo; a real deployment should scope this to an operator group
         that legitimately sees order data. -->
    <moqui.security.ArtifactGroup artifactGroupId="AI_OPS_DATA_READ" description="Read-only business data the AI Ops agent tools summarize (orders, etc.)"/>
    <moqui.security.ArtifactGroupMember artifactGroupId="AI_OPS_DATA_READ"
        artifactName="org\.apache\.ofbiz\.order\..*" artifactTypeEnumId="AT_ENTITY" nameIsPattern="Y"/>
    <moqui.security.ArtifactAuthz artifactAuthzId="AI_OPS_DATA_READ_ALL" userGroupId="ALL_USERS"
        artifactGroupId="AI_OPS_DATA_READ" authzTypeEnumId="AUTHZT_ALLOW" authzActionEnumId="AUTHZA_VIEW"/>
</entity-facade-xml>
