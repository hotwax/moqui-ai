<?xml version="1.0" encoding="UTF-8"?>
<entity-facade-xml type="ext-seed">
    <moqui.basic.StatusType statusTypeId="AiAgentRunStatus" description="AI Agent Run Status"/>
    <moqui.basic.StatusType statusTypeId="AiAgentStatus" description="AI Agent Status"/>

    <moqui.basic.StatusItem statusId="AI_RUN_RUNNING"   statusTypeId="AiAgentRunStatus" sequenceNum="1" description="Running"/>
    <moqui.basic.StatusItem statusId="AI_RUN_COMPLETED" statusTypeId="AiAgentRunStatus" sequenceNum="2" description="Completed"/>
    <moqui.basic.StatusItem statusId="AI_RUN_FAILED"    statusTypeId="AiAgentRunStatus" sequenceNum="3" description="Failed"/>
    <moqui.basic.StatusItem statusId="AI_RUN_TRUNCATED" statusTypeId="AiAgentRunStatus" sequenceNum="4" description="Truncated"/>
    <moqui.basic.StatusItem statusId="AI_RUN_ABORTED"   statusTypeId="AiAgentRunStatus" sequenceNum="5" description="Aborted"/>

    <moqui.basic.StatusItem statusId="AI_AGENT_DRAFT"    statusTypeId="AiAgentStatus" sequenceNum="0" description="Draft"/>
    <moqui.basic.StatusItem statusId="AI_AGENT_ACTIVE"   statusTypeId="AiAgentStatus" sequenceNum="1" description="Active"/>
    <moqui.basic.StatusItem statusId="AI_AGENT_DISABLED" statusTypeId="AiAgentStatus" sequenceNum="2" description="Disabled"/>

    <moqui.basic.StatusFlow statusFlowId="AiAgentRunFlow" statusTypeId="AiAgentRunStatus" description="AI agent run lifecycle"/>
    <moqui.basic.StatusFlow statusFlowId="AiAgentFlow"    statusTypeId="AiAgentStatus"    description="AI agent enable/disable"/>

    <!-- run: RUNNING -> terminal -->
    <moqui.basic.StatusFlowTransition statusFlowId="AiAgentRunFlow" statusId="AI_RUN_RUNNING" toStatusId="AI_RUN_COMPLETED" transitionSequence="1" transitionName="Complete"/>
    <moqui.basic.StatusFlowTransition statusFlowId="AiAgentRunFlow" statusId="AI_RUN_RUNNING" toStatusId="AI_RUN_FAILED"    transitionSequence="2" transitionName="Fail"/>
    <moqui.basic.StatusFlowTransition statusFlowId="AiAgentRunFlow" statusId="AI_RUN_RUNNING" toStatusId="AI_RUN_TRUNCATED" transitionSequence="3" transitionName="Truncate"/>
    <moqui.basic.StatusFlowTransition statusFlowId="AiAgentRunFlow" statusId="AI_RUN_RUNNING" toStatusId="AI_RUN_ABORTED"   transitionSequence="4" transitionName="Abort"/>

    <!-- agent: DRAFT -> ACTIVE | DISABLED; ACTIVE <-> DISABLED -->
    <moqui.basic.StatusFlowTransition statusFlowId="AiAgentFlow" statusId="AI_AGENT_ACTIVE"   toStatusId="AI_AGENT_DISABLED" transitionSequence="1" transitionName="Disable"/>
    <moqui.basic.StatusFlowTransition statusFlowId="AiAgentFlow" statusId="AI_AGENT_DISABLED" toStatusId="AI_AGENT_ACTIVE"   transitionSequence="2" transitionName="Enable"/>
    <moqui.basic.StatusFlowTransition statusFlowId="AiAgentFlow" statusId="AI_AGENT_DRAFT"    toStatusId="AI_AGENT_ACTIVE"   transitionSequence="3" transitionName="Activate"/>
    <moqui.basic.StatusFlowTransition statusFlowId="AiAgentFlow" statusId="AI_AGENT_DRAFT"    toStatusId="AI_AGENT_DISABLED" transitionSequence="4" transitionName="Disable draft"/>

    <!-- run: RUNNING <-> SUSPENDED (human-approval gate) -->
    <moqui.basic.StatusItem statusId="AI_RUN_SUSPENDED" statusTypeId="AiAgentRunStatus" sequenceNum="60" description="Suspended (awaiting approval)"/>
    <moqui.basic.StatusFlowTransition statusFlowId="AiAgentRunFlow" statusId="AI_RUN_RUNNING"   toStatusId="AI_RUN_SUSPENDED" transitionSequence="50" transitionName="Suspend"/>
    <moqui.basic.StatusFlowTransition statusFlowId="AiAgentRunFlow" statusId="AI_RUN_SUSPENDED" toStatusId="AI_RUN_RUNNING"   transitionSequence="51" transitionName="Resume"/>

    <!-- approval: PENDING -> APPROVED | REJECTED -->
    <moqui.basic.StatusType statusTypeId="AiToolCallRequestStatus" description="AI Tool Call Request Status"/>
    <moqui.basic.StatusItem statusId="AI_TCREQ_PENDING"  statusTypeId="AiToolCallRequestStatus" sequenceNum="1" description="Pending"/>
    <moqui.basic.StatusItem statusId="AI_TCREQ_APPROVED" statusTypeId="AiToolCallRequestStatus" sequenceNum="2" description="Approved"/>
    <moqui.basic.StatusItem statusId="AI_TCREQ_REJECTED" statusTypeId="AiToolCallRequestStatus" sequenceNum="3" description="Rejected"/>
    <moqui.basic.StatusFlow statusFlowId="AiToolCallRequestFlow" statusTypeId="AiToolCallRequestStatus" description="Approval decision"/>
    <moqui.basic.StatusFlowTransition statusFlowId="AiToolCallRequestFlow" statusId="AI_TCREQ_PENDING" toStatusId="AI_TCREQ_APPROVED" transitionSequence="1" transitionName="Approve"/>
    <moqui.basic.StatusFlowTransition statusFlowId="AiToolCallRequestFlow" statusId="AI_TCREQ_PENDING" toStatusId="AI_TCREQ_REJECTED" transitionSequence="2" transitionName="Reject"/>

    <!-- AiTool effect (Enumeration: fixed, code-referenced type, no lifecycle) -->
    <moqui.basic.EnumerationType enumTypeId="AiToolEffect" description="AI Tool Effect"/>
    <moqui.basic.Enumeration enumId="AI_TOOL_READ_ONLY" enumTypeId="AiToolEffect" sequenceNum="1" description="Read-only"/>
    <moqui.basic.Enumeration enumId="AI_TOOL_MUTATING"  enumTypeId="AiToolEffect" sequenceNum="2" description="Mutating"/>

    <!-- AiTool status -->
    <moqui.basic.StatusType statusTypeId="AiToolStatus" description="AI Tool Status"/>
    <moqui.basic.StatusItem statusId="AI_TOOL_ACTIVE"   statusTypeId="AiToolStatus" sequenceNum="1" description="Active"/>
    <moqui.basic.StatusItem statusId="AI_TOOL_DISABLED" statusTypeId="AiToolStatus" sequenceNum="2" description="Disabled"/>
    <moqui.basic.StatusFlow statusFlowId="AiToolFlow" statusTypeId="AiToolStatus" description="AI tool enable/disable"/>
    <moqui.basic.StatusFlowTransition statusFlowId="AiToolFlow" statusId="AI_TOOL_ACTIVE"   toStatusId="AI_TOOL_DISABLED" transitionSequence="1" transitionName="Disable"/>
    <moqui.basic.StatusFlowTransition statusFlowId="AiToolFlow" statusId="AI_TOOL_DISABLED" toStatusId="AI_TOOL_ACTIVE"   transitionSequence="2" transitionName="Enable"/>

    <!-- Capability-request queue (Composer gap -> Curator) -->
    <moqui.basic.StatusType statusTypeId="AiCapReqStatus" description="AI Capability Request Status"/>
    <moqui.basic.StatusItem statusId="AI_CAPREQ_OPEN"      statusTypeId="AiCapReqStatus" sequenceNum="1" description="Open"/>
    <moqui.basic.StatusItem statusId="AI_CAPREQ_DONE"      statusTypeId="AiCapReqStatus" sequenceNum="2" description="Fulfilled"/>
    <moqui.basic.StatusItem statusId="AI_CAPREQ_DISMISSED" statusTypeId="AiCapReqStatus" sequenceNum="3" description="Dismissed"/>
    <moqui.basic.StatusFlow statusFlowId="AiCapReqFlow" statusTypeId="AiCapReqStatus" description="Capability request lifecycle"/>
    <moqui.basic.StatusFlowTransition statusFlowId="AiCapReqFlow" statusId="AI_CAPREQ_OPEN" toStatusId="AI_CAPREQ_DONE"      transitionSequence="1" transitionName="Fulfill"/>
    <moqui.basic.StatusFlowTransition statusFlowId="AiCapReqFlow" statusId="AI_CAPREQ_OPEN" toStatusId="AI_CAPREQ_DISMISSED" transitionSequence="2" transitionName="Dismiss"/>

    <!-- Denylist floor: admin/security/internal service patterns (spec §4.4/§6.3). Non-overridable. -->
    <moqui.ai.AiToolDenylist servicePattern=".*\.delete#.*"          reason="Deletes must not be AI-exposable"/>
    <moqui.ai.AiToolDenylist servicePattern="org\.moqui\.impl\..*"    reason="Framework-internal services"/>
    <moqui.ai.AiToolDenylist servicePattern=".*[Pp]assword.*"         reason="Credential/security services"/>
    <moqui.ai.AiToolDenylist servicePattern=".*UserAccount.*"         reason="User/account administration"/>
    <moqui.ai.AiToolDenylist servicePattern=".*ArtifactAuthz.*"       reason="Authorization administration"/>
</entity-facade-xml>
