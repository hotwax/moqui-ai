<?xml version="1.0" encoding="UTF-8"?>
<entities xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/entity-definition-3.xsd">

    <!-- =====================================================================================
         moqui-ai data model — all entities (package moqui.ai), grouped by subsystem in the
         same order the system is explained (see docs/explanation/architecture.md and
         docs/reference/entities.md).

         Entity-ECA rules live separately in AiGlossaryEcas.eecas.xml: Moqui auto-scans
         entity/*.eecas.xml, and ECAs cannot live inside an <entities> document.

         We own every entity here and are pre-release, so definitions are edited IN PLACE
         (not via extend-entity, which is for extending base/platform entities we don't own).
         ===================================================================================== -->

    <!-- ============================ 1. Registry (the keystone) ============================
         What an agent and a tool ARE: opaque ids; the verb_noun tool catalog; the
         exposable + denylist safety floor; agent->tool grants; the provider failover chain. -->
    <entity entity-name="AiAgent" package="moqui.ai">
        <field name="agentId" type="id" is-pk="true"><description>Opaque, stable identity (sequenced for user-created; explicit stable id in seed data).</description></field>
        <field name="agentName" type="text-short"><description>Editable, human-friendly label. Unique across agents.</description></field>
        <field name="description" type="text-long"><description>What the agent is for (authored with guidance; may seed the prompt).</description></field>
        <field name="providerName" type="text-short"/>
        <field name="modelName" type="text-medium"/>
        <field name="systemPrompt" type="text-very-long"/>
        <field name="responseSchema" type="text-very-long"><description>Optional JSON Schema (as text). When set, run#Agent returns a typed structuredResult Map; adapters translate to the provider's native structured-output mechanism.</description></field>
        <field name="contextStrategy" type="text-short"><description>off (default) | window. window = bound the replayed history + offer the remember tool + inject pinned facts (ADR 0001 Phase 1).</description></field>
        <field name="contextWindowMessages" type="number-integer"><description>When contextStrategy=window: max replayed prior-turn messages to keep (current turn always kept). Default 20 when unset.</description></field>
        <field name="contextWindowChars" type="number-integer"><description>When contextStrategy=window: char-estimate guard (~chars/4 tokens) for the assembled view. Default 48000 when unset.</description></field>
        <field name="knowledgeMaxChars" type="number-integer">
            <description>Optional per-agent override of the injected-knowledge char cap. Null = use ai_knowledge_max_chars config default (24000).</description>
        </field>
        <field name="reasoningEffort" type="text-short"><description>none (default/unset) | low | medium | high. Provider-agnostic reasoning depth. OpenAI → reasoning_effort (reasoning-capable models only). Anthropic → extended thinking budget; v1 applies it ONLY to agents WITHOUT tool grants (reasoning+tools on Anthropic is deferred — needs thinking-block preservation across tool turns). No effect on providers/models that don't support reasoning.</description></field>
        <field name="maxIterations" type="number-integer"/>
        <field name="maxTokens" type="number-integer"/>
        <field name="maxCost" type="number-decimal"/>
        <field name="maxToolCallsPerTurn" type="number-integer"/>
        <field name="statusId" type="id"><description>StatusItem statusTypeId=AiAgentStatus: AI_AGENT_DRAFT | AI_AGENT_ACTIVE | AI_AGENT_DISABLED</description></field>
        <relationship type="one" related="moqui.basic.StatusItem" short-alias="status"/>
        <!-- explicit reverse for the agent's tool grants, so the entity-REST master can nest them -->
        <relationship type="many" related="moqui.ai.AiAgentTool" short-alias="grants"><key-map field-name="agentId"/></relationship>
        <index name="AI_AGENT_NAME" unique="true"><index-field name="agentName"/></index>
        <!-- entity-REST master (GET .../AiAgent/{id} with master=detail): the agent + its grants (each with
             its tool) + status, replacing ai.AgentServices.get#AgentDetail. The client derives
             effectiveRequiresApproval = grant.requiresApprovalOverride ?: tool.requiresApproval. -->
        <master name="detail">
            <detail relationship="grants"><detail relationship="tool"><detail relationship="effect"/></detail></detail>
            <detail relationship="status"/>
        </master>
    </entity>

    <entity entity-name="AiTool" package="moqui.ai">
        <field name="toolId" type="id" is-pk="true"><description>Opaque, stable identity (sequenced for user-created; explicit stable id in seed data). Renaming never breaks grants/history.</description></field>
        <field name="toolName" type="text-short"><description>Derived verb_noun, snake_case, wire-safe (^[a-z0-9_]+$). The LLM-facing name. Unique across tools.</description></field>
        <field name="verb" type="text-short"><description>Editable verb, e.g. list, cancel.</description></field>
        <field name="noun" type="text-short"><description>Editable noun, e.g. orders, return.</description></field>
        <field name="description" type="text-long"><description>LLM-facing "what / when to use".</description></field>
        <field name="serviceName" type="text-medium"><description>Backing Moqui service FQN — an attribute, NOT a key.</description></field>
        <field name="effectEnumId" type="id"><description>Enumeration enumTypeId=AiToolEffect: AI_TOOL_READ_ONLY | AI_TOOL_MUTATING (derived from the service verb).</description></field>
        <field name="exposable" type="text-indicator"><description>Y/N — may agents be granted this tool at all (denylist forces N).</description></field>
        <field name="requiresApproval" type="text-indicator"><description>Y/N — run-time human gate (Phase 4: a proposed call suspends the run; see AiToolCallRequest).</description></field>
        <field name="sourceComponent" type="text-medium"><description>Provenance: which component seeded it; null if user-authored.</description></field>
        <field name="createdByUserId" type="id"><description>Provenance for user-authored tools.</description></field>
        <field name="statusId" type="id"><description>StatusItem statusTypeId=AiToolStatus: AI_TOOL_ACTIVE | AI_TOOL_DISABLED.</description></field>
        <relationship type="one" related="moqui.basic.Enumeration" title="AiToolEffect" short-alias="effect">
            <key-map field-name="effectEnumId" related="enumId"/>
        </relationship>
        <relationship type="one" related="moqui.basic.StatusItem" short-alias="status"/>
        <index name="AI_TOOL_NAME" unique="true"><index-field name="toolName"/></index>
        <!-- a tool read carries its resolved effect (read-only/mutating) + status -->
        <master><detail relationship="effect"/><detail relationship="status"/></master>
    </entity>

    <!-- Non-overridable floor (spec D4/§6.3): service-name regex patterns that may NEVER become tools.
         Checked by store#AiTool; a match forces exposable=N and refuses any override. -->
    <entity entity-name="AiToolDenylist" package="moqui.ai">
        <field name="servicePattern" type="text-medium" is-pk="true"><description>Regex of service names that may never be exposed as a tool.</description></field>
        <field name="reason" type="text-medium"><description>Why — shown to the Curator.</description></field>
    </entity>

    <entity entity-name="AiAgentTool" package="moqui.ai">
        <field name="agentId" type="id" is-pk="true"/>
        <field name="toolId" type="id" is-pk="true"/>
        <field name="requiresApprovalOverride" type="text-indicator"><description>Optional Y/N — lets one agent be stricter than the tool's default requiresApproval (never looser; the tool default is a floor).</description></field>
        <relationship type="one" related="moqui.ai.AiAgent" short-alias="agent"/>
        <!-- one-nofk: the tool may be a seeded/user row; keep the grant resilient to catalog edits. -->
        <relationship type="one-nofk" related="moqui.ai.AiTool" short-alias="tool"/>
        <!-- a grant read carries its tool (with the tool's resolved effect) -->
        <master><detail relationship="tool"><detail relationship="effect"/></detail></master>
    </entity>

    <entity entity-name="AiAgentModel" package="moqui.ai">
        <field name="agentId" type="id" is-pk="true"/>
        <field name="priority" type="number-integer" is-pk="true"><description>Lower is tried first (0,1,2,...). Sticky failover advances on provider-call failure.</description></field>
        <field name="providerName" type="text-short"/>
        <field name="modelName" type="text-medium"/>
        <!-- one-nofk: config child; keep agent delete/test-cleanup unencumbered (mirrors AiAgentRun) -->
        <relationship type="one-nofk" related="moqui.ai.AiAgent" short-alias="agent"/>
    </entity>

    <!-- ============================ 2. Execution & observability ==========================
         One AiAgentRun per invocation -> ordered AiAgentRunStep rows -> AiToolCall per
         dispatched tool. Append-only audit. -->
    <entity entity-name="AiAgentRun" package="moqui.ai">
        <field name="agentRunId" type="id" is-pk="true"/>
        <field name="agentId" type="id"><description>The agent that produced this run (FK by id).</description></field>
        <field name="agentName" type="text-short"><description>Denormalized snapshot of the agent's label AT RUN TIME, so history reads correctly after a rename.</description></field>
        <field name="userId" type="id"/>
        <field name="startedDate" type="date-time"><description>When the run started.</description></field>
        <field name="endedDate" type="date-time"><description>When the run reached a terminal status; null while RUNNING/SUSPENDED. Duration = endedDate - startedDate (derived, not stored).</description></field>
        <field name="statusId" type="id"><description>StatusItem statusTypeId=AiAgentRunStatus: AI_RUN_RUNNING|AI_RUN_COMPLETED|AI_RUN_FAILED|AI_RUN_TRUNCATED|AI_RUN_ABORTED</description></field>
        <field name="providerName" type="text-short"/>
        <field name="modelName" type="text-medium"/>
        <field name="servedByModelId" type="text-medium"><description>The model that actually served the run; differs from the configured primary when fallback occurred</description></field>
        <field name="providerRunId" type="text-medium"><description>The provider's own response id (OpenAI id / Anthropic message id), for support correlation</description></field>
        <field name="userMessage" type="text-very-long"/>
        <field name="assistantMessage" type="text-very-long"/>
        <field name="iterations" type="number-integer"/>
        <field name="tokensIn" type="number-integer"/>
        <field name="tokensOut" type="number-integer"/>
        <field name="estimatedCost" type="number-decimal"/>
        <field name="errorText" type="text-very-long"/>
        <field name="pendingState" type="text-very-long"><description>Phase 4: JSON loop state when AI_RUN_SUSPENDED (messages, replayCount, stepSeq, candIdx, summary, result, turnToolCalls)</description></field>
        <field name="conversationId" type="id"><description>Phase 2: the conversation this run belongs to (optional)</description></field>
        <field name="isPreview" type="text-indicator"><description>Composer: Y when this run is a sandbox preview (ComposerServices.preview#Agent / AgentRunner.runPreview), where mutating tools are force-gated so the run SUSPENDS to show would-be calls without executing them. The run is throwaway, so its AI_RUN_SUSPENDED row + AI_TCREQ_PENDING tool call requests are excluded from the operator queue (ToolCallRequestServices.get#PendingToolCallRequest, screen/AiOps/Approvals.xml) and deleted by discard#Draft. Null/absent = a normal run.</description></field>
        <!-- one-nofk: AiAgentRun is append-only audit; it must not block the agent / conversation lifecycle -->
        <relationship type="one-nofk" related="moqui.ai.AiAgent" short-alias="agent"/>
        <relationship type="one-nofk" related="moqui.ai.AiConversation" short-alias="conversation"/>
        <relationship type="one" related="moqui.basic.StatusItem" short-alias="status"/>
        <!-- explicit reverse for human-approval gate rows, so the AiConversation master nests run -> requests -->
        <relationship type="many" related="moqui.ai.AiToolCallRequest" short-alias="toolCallRequests"><key-map field-name="agentRunId"/></relationship>
        <!-- a run read carries its tool-call requests + resolved status -->
        <master><detail relationship="toolCallRequests"/><detail relationship="status"/></master>
    </entity>

    <entity entity-name="AiAgentRunStep" package="moqui.ai">
        <field name="agentRunId" type="id" is-pk="true"/>
        <field name="stepSeqId" type="id" is-pk="true"/>
        <field name="stepType" type="text-short"><description>The kind of step: llm_call | context_trim | compaction. (Outcome lives in success; a failed llm call is stepType=llm_call, success=N.)</description></field>
        <field name="tokensIn" type="number-integer"/>
        <field name="tokensOut" type="number-integer"/>
        <field name="finishReason" type="text-short"/>
        <field name="success" type="text-indicator"><description>Y/N outcome of an llm_call step (a failed failover attempt = N). Null/Y for non-call steps.</description></field>
        <relationship type="one" related="moqui.ai.AiAgentRun" short-alias="run"/>
    </entity>

    <entity entity-name="AiToolCall" package="moqui.ai">
        <field name="agentRunId" type="id" is-pk="true"/>
        <field name="stepSeqId" type="id" is-pk="true"/>
        <field name="toolCallId" type="id" is-pk="true"/>
        <field name="toolId" type="id"><description>The tool that was called (id); toolName/serviceName are display/dispatch snapshots.</description></field>
        <field name="toolName" type="text-medium"/>
        <field name="serviceName" type="text-medium"/>
        <field name="arguments" type="text-very-long"/>
        <field name="result" type="text-very-long"/>
        <field name="success" type="text-indicator"/>
        <field name="errorText" type="text-very-long"/>
        <field name="durationMs" type="number-integer"/>
    </entity>

    <!-- ============================ 3. Human-approval gate ================================
         One pending decision per approval-required tool call in a suspended turn. -->
    <entity entity-name="AiToolCallRequest" package="moqui.ai">
        <field name="toolCallRequestId" type="id" is-pk="true"/>
        <field name="agentRunId" type="id"/>
        <field name="stepSeqId" type="id"/>
        <field name="toolCallId" type="id"/>
        <field name="toolName" type="text-medium"/>
        <field name="serviceName" type="text-medium"/>
        <field name="arguments" type="text-very-long"><description>JSON of the proposed call args</description></field>
        <field name="statusId" type="id"><description>StatusItem statusTypeId=AiToolCallRequestStatus: AI_TCREQ_PENDING|AI_TCREQ_APPROVED|AI_TCREQ_REJECTED</description></field>
        <field name="requestedByUserId" type="id"/>
        <field name="requestedDate" type="date-time"/>
        <field name="decidedByUserId" type="id"/>
        <field name="decidedDate" type="date-time"/>
        <field name="decisionNote" type="text-long"/>
        <!-- one-nofk: append-only audit; must not block the run/agent lifecycle (mirrors AiAgentRun) -->
        <relationship type="one-nofk" related="moqui.ai.AiAgentRun" short-alias="run"/>
        <relationship type="one" related="moqui.basic.StatusItem" short-alias="status"/>
        <!-- a request read carries its resolved status -->
        <master><detail relationship="status"/></master>
    </entity>

    <!-- Operator queue source: AiToolCallRequest joined to its run's isPreview, so the pending queue can be
         served by entity REST (GET .../AiToolCallRequestActivity?statusId=AI_TCREQ_PENDING) and exclude
         throwaway preview runs (filter isPreview != Y) without a bespoke service. join-optional so a request
         whose run row is gone still appears. Replaces ai.ToolCallRequestServices.get#PendingToolCallRequest. -->
    <view-entity entity-name="AiToolCallRequestActivity" package="moqui.ai">
        <member-entity entity-alias="TCR" entity-name="moqui.ai.AiToolCallRequest"/>
        <member-entity entity-alias="RUN" entity-name="moqui.ai.AiAgentRun" join-from-alias="TCR" join-optional="true">
            <key-map field-name="agentRunId"/>
        </member-entity>
        <alias-all entity-alias="TCR"/>
        <alias name="isPreview" entity-alias="RUN"/>
        <alias name="conversationId" entity-alias="RUN"/>
    </view-entity>

    <!-- ============================ 4. Conversation & context ============================= -->
    <entity entity-name="AiConversation" package="moqui.ai">
        <field name="conversationId" type="id" is-pk="true"/>
        <field name="agentId" type="id" required="true"><description>The agent this conversation belongs to (by id).</description></field>
        <field name="userId" type="id"/>
        <field name="title" type="text-medium"/>
        <field name="createdDate" type="date-time"><description>When the conversation was created.</description></field>
        <field name="summaryText" type="text-very-long"><description>ADR 0001 Phase 2: rolling summary of turns older than summaryThruMessageSeqId (compaction)</description></field>
        <field name="summaryThruMessageSeqId" type="id"><description>Watermark: messageSeqId of the newest message already folded into summaryText</description></field>
        <field name="statusId" type="id"><description>StatusItem statusTypeId=AiConversationStatus: AI_CONV_ACTIVE | AI_CONV_CLOSED</description></field>
        <relationship type="one-nofk" related="moqui.ai.AiAgent" short-alias="agent"/>
        <relationship type="one" related="moqui.basic.StatusItem" short-alias="status"/>
        <!-- explicit reverses so the entity-REST master can nest the whole thread in one read -->
        <relationship type="many" related="moqui.ai.AiConversationMessage" short-alias="messages"><key-map field-name="conversationId"/></relationship>
        <relationship type="many" related="moqui.ai.AiAgentRun" short-alias="runs"><key-map field-name="conversationId"/></relationship>
        <!-- entity-REST master (GET .../AiConversation/{id} with master=detail): the conversation + agent +
             ordered messages + its runs (each with its tool-call requests), replacing
             ai.WorkforceServices.get#ConversationDetail. The client parses message.toolCalls (stored JSON),
             picks the latest run by startedDate, and filters PENDING requests. -->
        <master name="detail">
            <detail relationship="agent"/>
            <detail relationship="messages"/>
            <detail relationship="runs"><detail relationship="toolCallRequests"/></detail>
            <detail relationship="status"/>
        </master>
    </entity>

    <!-- One persisted message per turn-part, in order, replayed on the next call. -->
    <entity entity-name="AiConversationMessage" package="moqui.ai">
        <field name="conversationId" type="id" is-pk="true"/>
        <field name="messageSeqId" type="id" is-pk="true"/>
        <field name="role" type="text-short"><description>system | user | assistant | tool</description></field>
        <field name="content" type="text-very-long"/>
        <field name="toolCalls" type="text-very-long"><description>JSON of List&lt;Map&gt; when an assistant turn requested tools</description></field>
        <field name="toolCallId" type="text-medium"><description>set when role = tool</description></field>
        <field name="agentRunId" type="id"><description>which run produced this message</description></field>
        <field name="createdDate" type="date-time"><description>When this message-part was recorded.</description></field>
        <relationship type="one" related="moqui.ai.AiConversation" short-alias="conversation"/>
    </entity>

    <!-- Pinned facts (ADR 0001 fidelity guarantee): durable confirmed business values an agent
         records via the `remember` tool. Conversation-scoped, keyed, store-or-update (a new value
         supersedes the old). Injected into every call's systemContext; never compressed/dropped. -->
    <entity entity-name="AiConversationFact" package="moqui.ai">
        <field name="conversationId" type="id" is-pk="true"/>
        <field name="factKey" type="text-medium" is-pk="true"/>
        <field name="factValue" type="text-very-long"/>
        <field name="agentRunId" type="id"><description>The run that last recorded this fact</description></field>
        <field name="createdDate" type="date-time"/>
        <!-- Moqui auto-adds lastUpdatedStamp = when the fact was last set (supersession time) -->
    </entity>

    <!-- Derived conversation list: lastActivityDate = MAX(message createdDate). Replaces the former
         denormalized AiConversation.lastActivityDate column (derive-don't-denormalize). join-optional
         so a conversation with no messages still appears (lastActivityDate = null). -->
    <view-entity entity-name="AiConversationActivity" package="moqui.ai">
        <member-entity entity-alias="CONV" entity-name="moqui.ai.AiConversation"/>
        <member-entity entity-alias="MSG" entity-name="moqui.ai.AiConversationMessage"
                join-from-alias="CONV" join-optional="true">
            <key-map field-name="conversationId"/>
        </member-entity>
        <alias-all entity-alias="CONV"/>
        <alias name="lastActivityDate" entity-alias="MSG" field="createdDate" function="max"/>
    </view-entity>

    <!-- ============================ 5. Cost ===============================================
         Effective-dated price per (provider, model). inputPrice/outputPrice are per 1,000,000
         tokens. A model's price changes over time; old runs keep the price current at run time. -->
    <entity entity-name="AiModelPrice" package="moqui.ai">
        <field name="providerName" type="text-short" is-pk="true"/>
        <field name="modelName" type="text-medium" is-pk="true"/>
        <field name="fromDate" type="date-time" is-pk="true"/>
        <field name="thruDate" type="date-time"/>
        <field name="inputPricePerMillion" type="currency-precise"/>
        <field name="outputPricePerMillion" type="currency-precise"/>
        <field name="currencyUomId" type="id"/>
    </entity>

    <!-- ====================== 6. Builder Knowledgebase / domain glossary ==================
         Curated domain nouns + capability verbs that ground agent/tool naming, their dialect
         synonyms, and the learning log of proposed-vs-kept names. -->
    <!-- The glossary: curated domain nouns + capability verbs, typed + provenanced + status-gated. -->
    <entity entity-name="AiDomainTerm" package="moqui.ai">
        <field name="termId" type="id" is-pk="true"/>
        <field name="term" type="text-short"><description>canonical term (order, cancel); unique per termKind + ownerScope</description></field>
        <field name="termKind" type="id"><description>Enumeration enumTypeId=AiTermKind: AI_TERM_NOUN | AI_TERM_VERB</description></field>
        <field name="description" type="text-long"/>
        <field name="sourceType" type="id"><description>Enumeration enumTypeId=AiTermSource: AI_TSRC_SEEDED | AI_TSRC_LEARNED | AI_TSRC_CURATED</description></field>
        <field name="statusId" type="id"><description>StatusItem statusTypeId=AiDomainTermStatus: AI_TERM_SUGGESTED | AI_TERM_APPROVED | AI_TERM_REJECTED</description></field>
        <field name="usageCount" type="number-integer"><description>chosen-in-authoring reinforcement count</description></field>
        <field name="ownerScope" type="id"><description>reserved for tenant/deployment scope; null = global in v1</description></field>
        <relationship type="one" related="moqui.basic.StatusItem" short-alias="status"/>
        <relationship type="one-nofk" title="AiTermKind" related="moqui.basic.Enumeration" short-alias="kindEnum">
            <key-map field-name="termKind" related="enumId"/></relationship>
        <index name="AI_TERM_UNIQUE" unique="true">
            <index-field name="term"/><index-field name="termKind"/><index-field name="ownerScope"/></index>
    </entity>

    <!-- The dialect: aliases that map to a canonical term ("rma" -> return). -->
    <entity entity-name="AiTermSynonym" package="moqui.ai">
        <field name="termId" type="id" is-pk="true"/>
        <field name="synonym" type="text-short" is-pk="true"/>
        <field name="sourceType" type="id"/>
        <field name="statusId" type="id"/>
        <relationship type="one" related="moqui.ai.AiDomainTerm" short-alias="domainTerm"/>
        <relationship type="one" related="moqui.basic.StatusItem" short-alias="status"/>
    </entity>

    <!-- The learning log: what the Composer proposed vs. what the human kept, per authoring event. -->
    <entity entity-name="AiNamingSignal" package="moqui.ai">
        <field name="signalId" type="id" is-pk="true"/>
        <field name="signalType" type="id"><description>Enumeration enumTypeId=AiSignalType: AI_SIG_TOOL_NAME | AI_SIG_AGENT_NAME</description></field>
        <field name="intentText" type="text-long"><description>the user's described intent / the backing service</description></field>
        <field name="suggestedName" type="text-medium"><description>what the Composer proposed (null if human-authored directly)</description></field>
        <field name="chosenName" type="text-medium"><description>what the human kept</description></field>
        <field name="wasOverridden" type="text-indicator"><description>Y if chosen != suggested</description></field>
        <field name="userId" type="id"/>
        <field name="createdDate" type="date-time"><description>When the signal was captured.</description></field>
    </entity>

    <!-- ============================ 7. Knowledge base =====================================
         Managed prose topics (bodies live as .md files in knowledge/; the entity is the
         queryable spine) assigned to agents and injected into the system context on each run. -->
    <entity entity-name="AiKnowledgeTopic" package="moqui.ai">
        <field name="topicId"         type="id"          is-pk="true"/>
        <field name="topicName"       type="text-short"/>
        <field name="description"     type="text-long"/>
        <field name="contentLocation" type="text-medium"/>
        <field name="statusId"        type="id"/>
        <field name="fromDate"        type="date-time"/>
        <field name="thruDate"        type="date-time"/>
        <field name="ownerScope"      type="id"/>
        <field name="createdByUserId" type="id"/>
        <relationship type="one" related="moqui.basic.StatusItem" short-alias="status"/>
        <index name="AI_KNOW_TOPIC_NAME" unique="true">
            <index-field name="topicName"/>
        </index>
    </entity>

    <entity entity-name="AiAgentKnowledge" package="moqui.ai">
        <field name="agentId"  type="id" is-pk="true"/>
        <field name="topicId"  type="id" is-pk="true"/>
        <relationship type="one"      related="moqui.ai.AiAgent"          short-alias="agent"/>
        <relationship type="one-nofk" related="moqui.ai.AiKnowledgeTopic" short-alias="topic"/>
    </entity>

    <!-- ============================ 8. Composer ===========================================
         A gap the Composer Assistant found but cannot fill (only the Curator may create tools).
         Append-only queue for the future Curator. -->
    <entity entity-name="AiCapabilityRequest" package="moqui.ai">
        <field name="capabilityRequestId" type="id" is-pk="true"/>
        <field name="intent" type="text-long"><description>what the user wanted, in their words</description></field>
        <field name="suggestedVerb" type="text-short"/>
        <field name="suggestedNoun" type="text-short"/>
        <field name="notes" type="text-long"/>
        <field name="requestedByUserId" type="id"/>
        <field name="agentRunId" type="id"><description>the compose run that surfaced the gap (provenance)</description></field>
        <field name="conversationId" type="id"/>
        <field name="requestedDate" type="date-time"/>
