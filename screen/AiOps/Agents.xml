<?xml version="1.0" encoding="UTF-8"?>
<screen xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/xml-screen-3.xsd"
        default-menu-title="Agents" require-authentication="true">

    <transition name="installDemo">
        <service-call name="notnaked.OmsAiServices.ensure#OmsAssistant"/>
        <default-response url="."/>
    </transition>
    <transition name="saveAgent">
        <service-call name="store#moqui.ai.AiAgent"
            in-map="[agentName:agentName, providerName:providerName, modelName:modelName,
                     maxIterations:maxIterations, statusId:statusId, systemPrompt:systemPrompt]"/>
        <default-response url="."/>
    </transition>

    <actions>
        <entity-find entity-name="moqui.ai.AiAgent" list="agentList"><order-by field-name="agentName"/></entity-find>
        <entity-find entity-name="moqui.ai.AiAgentTool" list="grantList"><order-by field-name="agentName,toolName"/></entity-find>
    </actions>

    <widgets>
        <container-box>
            <box-header title="Installed agents"/>
            <box-body>
                <label text="No agents yet? Click Install to create the NotNaked OMS Assistant, then run it from the Playground tab." type="p"/>
                <form-list name="AgentList" list="agentList">
                    <field name="agentName"><default-field><display/></default-field></field>
                    <field name="providerName"><default-field title="Provider"><display/></default-field></field>
                    <field name="modelName"><default-field title="Model"><display/></default-field></field>
                    <field name="statusId"><default-field title="Status"><display/></default-field></field>
                    <field name="maxIterations"><default-field title="Max iter"><display/></default-field></field>
                </form-list>
                <form-single name="InstallDemo" transition="installDemo">
                    <field name="install"><default-field title=""><submit text="Install NotNaked OMS Assistant"/></default-field></field>
                </form-single>
            </box-body>
        </container-box>

        <container-box>
            <box-header title="Tool grants"/>
            <box-body>
                <form-list name="GrantList" list="grantList">
                    <field name="agentName"><default-field><display/></default-field></field>
                    <field name="toolName"><default-field title="Tool (service)"><display/></default-field></field>
                </form-list>
            </box-body>
        </container-box>

        <container-box>
            <box-header title="Add / update an agent"/>
            <box-body>
                <form-single name="AgentForm" transition="saveAgent">
                    <field name="agentName"><default-field title="Agent name"><text-line size="30"/></default-field></field>
                    <field name="providerName"><default-field title="Provider">
                        <drop-down><option key="openai" text="openai"/><option key="anthropic" text="anthropic"/><option key="google" text="google"/></drop-down></default-field></field>
                    <field name="modelName"><default-field title="Model"><text-line size="30" default-value="gpt-4o-mini"/></default-field></field>
                    <field name="maxIterations"><default-field title="Max iterations"><text-line size="4" default-value="5"/></default-field></field>
                    <field name="statusId"><default-field title="Status">
                        <drop-down><option key="AI_AGENT_ACTIVE" text="Active"/><option key="AI_AGENT_DISABLED" text="Disabled"/></drop-down></default-field></field>
                    <field name="systemPrompt"><default-field title="System prompt"><text-area rows="4" cols="80"/></default-field></field>
                    <field name="submitField"><default-field title=""><submit text="Save agent"/></default-field></field>
                </form-single>
            </box-body>
        </container-box>
    </widgets>
</screen>
