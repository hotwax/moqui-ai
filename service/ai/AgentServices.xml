<?xml version="1.0" encoding="UTF-8"?>
<services xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/service-definition-3.xsd">

    <!-- transaction="ignore": the loop holds NO enclosing tx; tool calls + observability
         writes each manage their own tx (see AgentRunner). -->
    <service verb="run" noun="Agent" transaction="ignore" authenticate="true">
        <in-parameters>
            <parameter name="agentId" required="true"/>
            <parameter name="userMessage" required="true"/>
            <parameter name="conversationId"><description>Optional. When set, prior turns are replayed and this turn is persisted.</description></parameter>
        </in-parameters>
        <out-parameters>
            <parameter name="assistantMessage"/>
            <parameter name="agentRunId"/>
            <parameter name="conversationId"/>
            <parameter name="tokensIn" type="Long"/>
            <parameter name="tokensOut" type="Long"/>
            <parameter name="iterations" type="Integer"/>
            <parameter name="truncated" type="Boolean"/>
            <parameter name="statusId"/>
            <parameter name="servedByModelId"/>
            <parameter name="providerName"/>
            <parameter name="estimatedCost" type="BigDecimal"/>
            <parameter name="providerRunId"/>
            <parameter name="structuredResult" type="Map"/>
            <parameter name="awaitingApproval" type="Boolean"/>
            <parameter name="toolCallRequestIds" type="List"/>
        </out-parameters>
        <actions>
            <script><![CDATA[
                def r = new org.moqui.ai.AgentRunner(ec).run(agentId, userMessage, conversationId)
                ec.context.putAll(r)   // the result map keys ARE the out-parameters
            ]]></script>
        </actions>
    </service>

    <!-- The Agent Composer authoring gate (spec D2/§6): sequences agentId, enforces unique agentName,
         defaults DRAFT. Composers can never expose a raw service (tools are authored via store#AiTool). -->
    <service verb="store" noun="AiAgent" authenticate="true">
        <in-parameters>
            <parameter name="agentId"><description>Omit to create (sequenced); set to update by stable id.</description></parameter>
            <parameter name="agentName"/>
            <parameter name="description"/>
            <parameter name="providerName"/><parameter name="modelName"/>
            <parameter name="systemPrompt"/><parameter name="responseSchema"/>
            <parameter name="contextStrategy"/><parameter name="contextWindowMessages" type="Integer"/>
            <parameter name="contextWindowChars" type="Integer"/><parameter name="reasoningEffort"/>
            <parameter name="maxIterations" type="Integer"/><parameter name="maxTokens" type="Integer"/>
            <parameter name="maxCost" type="BigDecimal"/><parameter name="maxToolCallsPerTurn" type="Integer"/>
            <parameter name="statusId"/>
            <!-- Builder Knowledgebase pass-through (inert to authoring; read only by capture#NamingSignal). -->
            <parameter name="suggestedName"><description>What the Composer proposed (null if human-authored directly).</description></parameter>
            <parameter name="intentText"><description>The user's described intent for this agent.</description></parameter>
        </in-parameters>
        <out-parameters><parameter name="agentId"/></out-parameters>
        <actions>
            <!-- unique agentName check (only when a name is given and it would collide with a DIFFERENT agent) -->
            <if condition="agentName">
                <entity-find entity-name="moqui.ai.AiAgent" list="nameClash">
                    <econdition field-name="agentName" from="agentName"/></entity-find>
                <iterate list="nameClash" entry="other">
                    <if condition="other.agentId != agentId">
                        <return error="true" message="An agent named '${agentName}' already exists (agentId ${other.agentId}); choose a different name."/>
                    </if>
                </iterate>
            </if>
            <if condition="!agentId">
                <set field="agentId" from="ec.entity.sequencedIdPrimary('moqui.ai.AiAgent', null, null)"/>
                <set field="statusId" from="statusId ?: 'AI_AGENT_DRAFT'"/>
                <!-- Make a freshly drafted agent runnable WITHOUT hand-editing: the user/Composer describes
                     WHAT it does, the system picks the model. Provider/model from MoquiConf
                     (ai_default_provider / ai_default_model) with hardcoded fallbacks; iteration bound + a
                     systemPrompt (falls back to the description) so preview/activate work out of the box.
                     Create-only — never overrides an explicit value on update. -->
                <set field="providerName" from="providerName ?: System.getProperty('ai_default_provider') ?: 'openai'"/>
                <set field="modelName" from="modelName ?: System.getProperty('ai_default_model') ?: 'gpt-4o-mini'"/>
                <set field="maxIterations" from="maxIterations ?: 5"/>
                <set field="systemPrompt" from="systemPrompt ?: description"/>
            </if>
            <!-- Builder Knowledgebase: mark captured-in-service BEFORE the write so the AiAgent EECA skips. -->
            <set field="ec.context.signalCaptured" value="true"/>
            <service-call name="store#moqui.ai.AiAgent" in-map="context"/>
            <!-- record the rich naming signal (suggested vs. chosen agentName, intent). Non-fatal. -->
            <service-call name="ai.GlossaryServices.capture#NamingSignal" in-map="[signalType: 'AI_SIG_AGENT_NAME',
                chosenName: agentName, suggestedName: suggestedName, intentText: intentText]"/>
        </actions>
    </service>

    <!-- Grant a catalog tool to an agent (the Composer's grant_capability backing service). An explicit
         service (not entity-auto store#moqui.ai.AiAgentTool) so it can be a tool: entity-auto services have
         no ServiceDefinition and cannot be introspected by ToolSchemaBuilder. Idempotent create-or-update;
         only exposable+active tools may be granted (the safety floor — a draft can never reference a service
         the Curator hasn't blessed). -->
    <service verb="store" noun="AiAgentTool" authenticate="true">
        <in-parameters>
            <parameter name="agentId" required="true"/>
            <parameter name="toolId" required="true"/>
            <parameter name="requiresApprovalOverride"><description>Optional Y/N — overrides the tool default in either direction.</description></parameter>
        </in-parameters>
        <out-parameters><parameter name="agentId"/><parameter name="toolId"/></out-parameters>
        <actions>
            <entity-find-one entity-name="moqui.ai.AiAgent" value-field="agent">
                <field-map field-name="agentId"/></entity-find-one>
            <if condition="agent == null"><return error="true" message="Unknown agent ${agentId}"/></if>
            <entity-find-one entity-name="moqui.ai.AiTool" value-field="tool">
                <field-map field-name="toolId"/></entity-find-one>
            <if condition="tool == null"><return error="true" message="Unknown tool ${toolId}"/></if>
            <if condition="tool.exposable != 'Y' || tool.statusId != 'AI_TOOL_ACTIVE'">
                <return error="true" message="Tool ${tool.toolName} (${toolId}) is not exposable/active and cannot be granted."/></if>
            <service-call name="store#moqui.ai.AiAgentTool"
                in-map="[agentId: agentId, toolId: toolId, requiresApprovalOverride: requiresApprovalOverride]"/>
        </actions>
    </service>

    <service verb="create" noun="Conversation" authenticate="true">
        <in-parameters>
            <parameter name="agentId" required="true"/>
            <parameter name="title"/>
        </in-parameters>
        <out-parameters><parameter name="conversationId"/></out-parameters>
        <actions>
            <entity-find-one entity-name="moqui.ai.AiAgent" value-field="agent" cache="true">
                <field-map field-name="agentId"/></entity-find-one>
            <if condition="agent == null"><return error="true" message="Unknown agent: ${agentId}"/></if>
            <set field="conversationId" from="ec.entity.sequencedIdPrimary('moqui.ai.AiConversation', null, null)"/>
            <service-call name="create#moqui.ai.AiConversation" in-map="[conversationId: conversationId,
                agentId: agentId, title: title, userId: ec.user.userId,
                createdDate: ec.user.nowTimestamp, statusId: 'AI_CONV_ACTIVE']"/>
        </actions>
    </service>

    <service verb="run" noun="Conversation" transaction="ignore" authenticate="true">
        <in-parameters>
            <parameter name="conversationId" required="true"/>
            <parameter name="userMessage" required="true"/>
        </in-parameters>
        <out-parameters>
            <parameter name="assistantMessage"/>
            <parameter name="agentRunId"/>
            <parameter name="conversationId"/>
            <parameter name="tokensIn" type="Long"/>
            <parameter name="tokensOut" type="Long"/>
            <parameter name="iterations" type="Integer"/>
            <parameter name="truncated" type="Boolean"/>
            <parameter name="statusId"/>
            <parameter name="servedByModelId"/>
            <parameter name="providerName"/>
            <parameter name="estimatedCost" type="BigDecimal"/>
            <parameter name="providerRunId"/>
            <parameter name="structuredResult" type="Map"/>
            <parameter name="awaitingApproval" type="Boolean"/>
            <parameter name="toolCallRequestIds" type="List"/>
        </out-parameters>
        <actions>
            <entity-find-one entity-name="moqui.ai.AiConversation" value-field="conv"/>
            <if condition="conv == null"><return error="true" message="Unknown conversation: ${conversationId}"/></if>
            <!-- Cross-user gate: this is the only REST path that drives a conversation (POST
                 /conversations/{id}/messages). Without it any authenticated user could inject a message into ANY
                 user's agent thread and consume their LLM spend. Owner, or an operator (AI_OPERATOR / ADMIN),
                 only — fail-closed before run#Agent. -->
            <if condition="conv.userId != ec.user.userId &amp;&amp; !ec.user.isInGroup('AI_OPERATOR') &amp;&amp; !ec.user.isInGroup('ADMIN')">
                <log level="warn" message="AI authz: user ${ec.user.userId} denied posting to conversation ${conversationId} owned by ${conv.userId} (not owner/AI_OPERATOR)."/>
                <return error="true" message="Not authorized to post to this conversation: it belongs to another user."/>
            </if>
            <service-call name="ai.AgentServices.run#Agent" out-map="context"
                in-map="[agentId: conv.agentId, userMessage: userMessage, conversationId: conversationId]"/>
        </actions>
    </service>

    <!-- Model + reasoning options for the PWA Composer dropdowns: registered providers with their
         current AiModelPrice models plus the configured default. mock is offered only when it is
         the sole registered provider (dev without keys). -->
    <service verb="list" noun="Model" authenticate="true">
        <out-parameters>
            <parameter name="modelList" type="List"><description>each: providerName, modelName</description></parameter>
            <parameter name="defaultProviderName"/><parameter name="defaultModelName"/>
            <parameter name="reasoningEffortList" type="List"/>
        </out-parameters>
        <actions>
            <script><![CDATA[
                def ai = ec.factory.getTool("AI", org.moqui.ai.AiToolFactory.class)
                Set<String> providers = (ai.getProviderNames().findAll { it != "mock" }) as Set
                if (!providers) providers = ["mock"] as Set
                defaultProviderName = System.getProperty('ai_default_provider') ?: System.getenv('ai_default_provider') ?: 'openai'
                defaultModelName = System.getProperty('ai_default_model') ?: System.getenv('ai_default_model') ?: 'gpt-4o-mini'
                modelList = []
                def now = ec.user.nowTimestamp
                for (def p in ec.entity.find("moqui.ai.AiModelPrice").orderBy("providerName").orderBy("modelName").list()) {
                    if (!(p.providerName in providers)) continue
                    if (p.thruDate != null && p.thruDate < now) continue
                    if (!modelList.any { it.providerName == p.providerName && it.modelName == p.modelName })
                        modelList.add([providerName: p.providerName, modelName: p.modelName])
                }
                if (providers.contains(defaultProviderName) &&
                        !modelList.any { it.providerName == defaultProviderName && it.modelName == defaultModelName })
                    modelList.add([providerName: defaultProviderName, modelName: defaultModelName])
                // Last-resort option must be a CONSISTENT provider+model pair. providers.first() may not be
                // the default provider, so pairing it with defaultModelName (e.g. anthropic + gpt-4o-mini)
                // would offer a combination that can never run. Offer the configured default pair (mutually
                // consistent by construction) or mock.
                if (!modelList) modelList.add(providers.first() == "mock"
                    ? [providerName: "mock", modelName: "mock-1"]
                    : [providerName: defaultProviderName, modelName: defaultModelName])
                reasoningEffortList = ["none", "low", "medium", "high"]
            ]]></script>
        </actions>
    </service>

    <service verb="generate" noun="ConversationTitle" authenticate="true" transaction="use">
        <in-parameters>
            <parameter name="conversationId" required="true"/>
            <parameter name="userMessage" required="true"/>
        </in-parameters>
        <actions>
            <script>org.moqui.ai.AgentRunner.generateConversationTitle(ec, conversationId, userMessage)</script>
        </actions>
    </service>
</services>
