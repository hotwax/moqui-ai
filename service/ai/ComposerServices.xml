<?xml version="1.0" encoding="UTF-8"?>
<services xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/service-definition-3.xsd">

    <!-- The Composer Assistant's meta-tools. Each is also an AiTool catalog row (data/AiComposerData.xml)
         granted to the composer-assistant agent. Authoring tools are ArtifactAuthz-gated to the Composer
         role (deferred to a v1 follow-up like the rest of the console; authenticate="true" for now).
         Reconciled to the shipped keystone: AiTool carries effectEnumId (not a plain "effect" field);
         services surface it under the ergonomic out-param "effect" for the LLM/screen. -->

    <!-- Search the catalog by intent/keyword/noun. ONLY exposable + active tools (grant-eligible). -->
    <service verb="find" noun="Capability" authenticate="true">
        <in-parameters>
            <parameter name="query"><description>intent/keyword/noun, matched against toolName, verb, noun, description</description></parameter>
            <parameter name="maxResults" type="Integer" default-value="25"/>
        </in-parameters>
        <out-parameters><parameter name="capabilityList" type="List"/></out-parameters>
        <actions>
            <!-- Only the grant-eligible (exposable + active) catalog; keyword-filter in Groovy so an empty
                 query returns all (a like '%${query}%' would render the literal '%null%' on a null query). -->
            <entity-find entity-name="moqui.ai.AiTool" list="toolList">
                <econdition field-name="exposable" value="Y"/>
                <econdition field-name="statusId" value="AI_TOOL_ACTIVE"/>
                <select-field field-name="toolId,toolName,verb,noun,description,effectEnumId,exposable,requiresApproval,statusId"/>
                <order-by field-name="toolName"/>
            </entity-find>
            <set field="capabilityList" from="[]"/>
            <script><![CDATA[
                String q = (query ?: "").toLowerCase().trim()
                int max = (maxResults ?: 25) as int
                // Tokenize the query; include a tool if ANY term hits its name/verb/noun/description,
                // ranked by how many terms hit. A whole-phrase contains() missed obvious matches —
                // e.g. query "summarize recent orders" vs a description containing "summarize" and
                // "orders" non-contiguously returned nothing.
                List<String> terms = q ? (q.split(/\s+/).findAll { it } as List) : []
                List scored = []
                for (def t in toolList) {
                    def m = t.getMap()
                    m.effect = m.effectEnumId   // ergonomic alias the LLM/screen reads
                    int hits = 0
                    if (terms) {
                        String hay = "${t.toolName ?: ''} ${t.verb ?: ''} ${t.noun ?: ''} ${t.description ?: ''}".toLowerCase()
                        hits = terms.count { hay.contains(it) } as int
                        if (hits == 0) continue
                    }
                    scored.add([m: m, hits: hits])
                }
                scored.sort { a, b -> b.hits <=> a.hits }   // best match first; stable for ties (toolName order)
                for (def s in scored) {
                    capabilityList.add(s.m)
                    if (capabilityList.size() >= max) break
                }
            ]]></script>
        </actions>
    </service>

    <!-- One tool's purpose + on-demand input schema, so the assistant can reason about fit. -->
    <service verb="describe" noun="Capability" authenticate="true">
        <in-parameters>
            <parameter name="toolId"/>
            <parameter name="toolName"><description>alternative lookup key</description></parameter>
        </in-parameters>
        <out-parameters>
            <parameter name="toolId"/><parameter name="toolName"/><parameter name="description"/>
            <parameter name="effect"/><parameter name="serviceName"/><parameter name="exposable"/>
            <parameter name="inputSchema" type="Map"/>
        </out-parameters>
        <actions>
            <entity-find entity-name="moqui.ai.AiTool" list="found">
                <econdition field-name="toolId" ignore-if-empty="true"/>
                <econdition field-name="toolName" ignore-if-empty="true"/>
            </entity-find>
            <if condition="!found"><return error="true" message="No such capability: ${toolId ?: toolName}"/></if>
            <set field="tool" from="found[0]"/>
            <script>
                context.toolId = tool.toolId; context.toolName = tool.toolName
                context.description = tool.description; context.effect = tool.effectEnumId
                context.serviceName = tool.serviceName; context.exposable = tool.exposable
                // schema generated on demand from the live service definition (never stored)
                context.inputSchema = org.moqui.ai.ToolSchemaBuilder.build(ec.factory, tool.serviceName as String)
            </script>
        </actions>
    </service>

    <!-- The business vocabulary the assistant grounds in. Now backed by the Builder Knowledgebase: the
         APPROVED domain glossary (ai.GlossaryServices) is the primary source, with the grant-eligible
         catalog nouns merged in as a floor. source flips to "knowledgebase" whenever the glossary
         contributes a term, else stays "catalog" (an un-seeded deployment behaves exactly like the v1
         stub). The contract (termList + source) is unchanged so the assistant needs no edit. -->
    <service verb="list" noun="DomainTerm" authenticate="true">
        <in-parameters><parameter name="query"/></in-parameters>
        <out-parameters>
            <parameter name="termList" type="List"/>
            <parameter name="source"><description>"catalog" (glossary empty) | "knowledgebase" (glossary contributed)</description></parameter>
        </out-parameters>
        <actions>
            <!-- catalog floor: distinct nouns from the grant-eligible catalog. Keyword-filter + de-dupe in
                 Groovy (an empty query must return all; a like '%${query}%' renders the literal '%null%'). -->
            <entity-find entity-name="moqui.ai.AiTool" list="toolList">
                <econdition field-name="exposable" value="Y"/>
                <econdition field-name="statusId" value="AI_TOOL_ACTIVE"/>
                <select-field field-name="noun"/><order-by field-name="noun"/>
            </entity-find>
            <script><![CDATA[
                String q = (query ?: "").toLowerCase().trim()
                List catalogNouns = toolList.collect { it.noun }.findAll { it && (!q || (it as String).toLowerCase().contains(q)) }.unique()

                // Builder Knowledgebase: real grounded terms. With a query, snap via lexical find; without
                // one, return all APPROVED glossary terms (the full grounding slice).
                List<String> kbTerms = []
                if (q) {
                    def found = ec.service.sync().name("ai.GlossaryServices.find#DomainTerm")
                        .parameters([text: query]).call()
                    kbTerms = (found.terms ?: []).collect { (it.term as String) }
                } else {
                    kbTerms = ec.entity.find("moqui.ai.AiDomainTerm").condition("statusId", "AI_TERM_APPROVED")
                        .orderBy("term").list().collect { (it.term as String) }
                }

                // glossary is primary; catalog nouns merged as a floor. source reflects whether the KB spoke.
                source = kbTerms ? "knowledgebase" : "catalog"
                termList = (kbTerms + catalogNouns).findAll { it }.unique()
            ]]></script>
        </actions>
    </service>

    <!-- Best-guess agent naming (decision §12.3): KB-grounded heuristic + optional LLM refinement.
         Wire-safe by construction. The grounding is REAL — list#DomainTerm is backed by the Builder
         Knowledgebase glossary, and the chosen noun is snapped to its canonical glossary term (so a
         dialect word like "rma" resolves to "return"). The LLM refinement runs AICMP_NAMING_AGENT through
         the run#Agent service (like enhance#Instructions); the agent's responseSchema yields a typed
         structuredResult, so there is no JSON parsing here. Best-effort: it falls back to the heuristic if
         the glossary is empty, the agent is missing, or no provider/key is configured — never fails the build. -->
    <service verb="propose" noun="Naming" authenticate="true" transaction="ignore">
        <in-parameters>
            <parameter name="intent" required="true"><description>what the user wants the agent to do</description></parameter>
        </in-parameters>
        <out-parameters>
            <parameter name="agentNameSuggestion"/>
            <parameter name="descriptionSuggestion"/>
        </out-parameters>
        <actions>
            <!-- heuristic floor: derive a wire-safe slug from the intent + KB-grounded nouns. list#DomainTerm
                 with no query returns the full grounding slice (APPROVED glossary terms + catalog nouns). -->
            <service-call name="ai.ComposerServices.list#DomainTerm" out-map="dtOut" in-map="[:]"/>
            <set field="terms" from="dtOut.termList ?: []"/>
            <!-- pick the first business term that appears in the intent (else the generic 'assistant') -->
            <set field="noun" from="terms.find { (intent as String).toLowerCase().contains((it as String).toLowerCase()) } ?: 'assistant'"/>
            <!-- snap a matched noun to its canonical glossary term (dialect -> canonical); best-effort -->
            <if condition="noun != 'assistant'">
                <service-call name="ai.GlossaryServices.propose#Naming" out-map="snapOut" ignore-error="true"
                    in-map="[proposedNoun: noun, intentText: intent]"/>
                <if condition="snapOut?.noun"><set field="noun" from="snapOut.noun"/></if>
            </if>
            <set field="slug" from="noun == 'assistant' ? 'assistant' : noun + '-assistant'"/>
            <set field="agentNameSuggestion" from="slug.toLowerCase().replaceAll('[^a-z0-9-]+', '-').replaceAll('-+', '-')"/>
            <set field="descriptionSuggestion" from="'Assistant for: ' + intent"/>
            <!-- optional LLM refinement: run the data-defined naming agent through the run#Agent service. Its
                 responseSchema yields a typed structuredResult (no JSON parsing). ignore-error keeps the
                 heuristic suggestion when the agent is missing or a provider/network call fails. -->
            <set field="namingMsg" from="'Intent: ' + intent + (terms ? ' Business terms to ground in: ' + terms.join(', ') + '.' : '')"/>
            <service-call name="ai.AgentServices.run#Agent" out-map="runOut" ignore-error="true"
                in-map="[agentId: 'AICMP_NAMING_AGENT', userMessage: namingMsg]"/>
            <if condition="runOut?.structuredResult?.name">
                <set field="agentNameSuggestion" from="(runOut.structuredResult.name as String).toLowerCase().replaceAll('[^a-z0-9-]+', '-').replaceAll('-+', '-')"/>
            </if>
            <if condition="runOut?.structuredResult?.description">
                <set field="descriptionSuggestion" from="runOut.structuredResult.description"/>
            </if>
        </actions>
    </service>

    <!-- Set per-grant approval strictness on a draft. Explicit per-grant trust in EITHER direction
         (ADR revision 2026-06-11): an agent can be stricter than the tool default, or loosen a gated
         tool when the composer explicitly trusts it — preview still force-gates all mutating tools.
         Writes the keystone's AiAgentTool.requiresApprovalOverride. -->
    <service verb="set" noun="Guardrail" authenticate="true">
        <in-parameters>
            <parameter name="agentId" required="true"/>
            <parameter name="toolId" required="true"/>
            <parameter name="requiresApproval" required="true"><description>Y/N</description></parameter>
        </in-parameters>
        <actions>
            <entity-find-one entity-name="moqui.ai.AiAgentTool" value-field="grant"/>
            <if condition="grant == null"><return error="true" message="Agent ${agentId} has no grant for tool ${toolId}"/></if>
            <service-call name="update#moqui.ai.AiAgentTool"
                in-map="[agentId: agentId, toolId: toolId, requiresApprovalOverride: requiresApproval]"/>
        </actions>
    </service>

    <!-- Record a capability gap for the Curator. The assistant calls this instead of fabricating a tool. -->
    <service verb="request" noun="Capability" authenticate="true">
        <in-parameters>
            <parameter name="intent" required="true"/>
            <parameter name="suggestedVerb"/><parameter name="suggestedNoun"/>
            <parameter name="notes"/><parameter name="agentRunId"/><parameter name="conversationId"/>
        </in-parameters>
        <out-parameters><parameter name="capabilityRequestId"/></out-parameters>
        <actions>
            <set field="capabilityRequestId" from="ec.entity.sequencedIdPrimary('moqui.ai.AiCapabilityRequest', null, null)"/>
            <service-call name="create#moqui.ai.AiCapabilityRequest" in-map="[capabilityRequestId: capabilityRequestId,
                intent: intent, suggestedVerb: suggestedVerb, suggestedNoun: suggestedNoun, notes: notes,
                agentRunId: agentRunId, conversationId: conversationId, requestedByUserId: ec.user.userId,
                requestedDate: ec.user.nowTimestamp, statusId: 'AI_CAPREQ_OPEN']"/>
        </actions>
    </service>

    <!-- PWA Composer "Enhance": rewrite rough instructions into a clear agent system prompt. Stateless —
         returns the rewrite only, never persists. The "enhancer" is the data-defined AICMP_ENHANCE_AGENT
         (prompt + model live in data/AiComposerData.xml, not hardcoded here); this service is a thin wrapper
         that runs it through AgentRunner for the normal observability/cost/fallback. transaction="ignore":
         run#Agent drives an LLM call that must hold no enclosing tx (mirrors run#Conversation). -->
    <service verb="enhance" noun="Instructions" authenticate="true" transaction="ignore">
        <in-parameters>
            <parameter name="instructions" required="true"/>
            <parameter name="agentName"/>
        </in-parameters>
        <out-parameters><parameter name="enhancedInstructions"/></out-parameters>
        <actions>
            <!-- fold the optional agentName into the message (the system prompt is fixed in data) -->
            <set field="enhanceMsg" from="instructions"/>
            <if condition="agentName"><set field="enhanceMsg" from="'Agent name: ' + agentName + '. Instructions to rewrite: ' + instructions"/></if>
            <service-call name="ai.AgentServices.run#Agent" out-map="runOut"
                in-map="[agentId: 'AICMP_ENHANCE_AGENT', userMessage: enhanceMsg]"/>
            <set field="enhancedInstructions" from="runOut.assistantMessage"/>
            <!-- graceful: a provider/network failure leaves a FAILED run with no text; never a raw 500 -->
            <if condition="!enhancedInstructions">
                <return error="true" message="Could not enhance instructions (the enhancement agent is unavailable or returned no text); instructions left unchanged."/>
            </if>
        </actions>
    </service>

    <!-- Sandbox-run a draft on a user-supplied test message. Mutating tools are held by the approval
         gate (AgentRunner.runPreview); read-only tools run on real data (decision §12.4). Returns the
         run result + the held (would-be) calls so the screen can show "would call X(...)".
         transaction="ignore": runPreview drives LLM calls that must hold no enclosing tx (mirrors run#Agent). -->
    <service verb="preview" noun="Agent" transaction="ignore" authenticate="true">
        <in-parameters>
            <parameter name="agentId" required="true"/>
            <parameter name="testMessage" required="true"/>
        </in-parameters>
        <out-parameters>
            <parameter name="agentRunId"/><parameter name="statusId"/>
            <parameter name="assistantMessage"/>
            <parameter name="heldCalls" type="List"><description>each: toolName, serviceName, arguments (JSON)</description></parameter>
        </out-parameters>
        <actions>
            <script><![CDATA[
                def ai = ec.factory.getTool("AI", org.moqui.ai.AiToolFactory.class)
                def r = new org.moqui.ai.AgentRunner(ec, ai).runPreview(agentId as String, testMessage as String)
                agentRunId = r.agentRunId; statusId = r.statusId; assistantMessage = r.assistantMessage
                heldCalls = []
                for (def a in ec.entity.find("moqui.ai.AiToolCallRequest").condition("agentRunId", agentRunId)
                        .condition("statusId", "AI_TCREQ_PENDING").orderBy("requestedDate").list())
                    heldCalls.add([toolName: a.toolName, serviceName: a.serviceName, arguments: a.arguments])
            ]]></script>
        </actions>
    </service>

    <!-- Commit: draft -> active. Re-checks every grant is still exposable + active (a tool can be
         un-exposed/disabled by the Curator after it was granted). Fail-loud on any non-exposable grant.
         HUMAN APPROVAL is enforced UPSTREAM: activate_agent is a requiresApproval AiTool, so the Composer
         Assistant proposing it suspends its own run via the existing gate; this service runs only after a
         human approves (decision §12.2). Also callable directly by an operator (the screen's Activate button). -->
    <service verb="activate" noun="Agent" authenticate="true">
        <in-parameters><parameter name="agentId" required="true"/></in-parameters>
        <out-parameters><parameter name="agentId"/><parameter name="statusId"/></out-parameters>
        <actions>
            <entity-find-one entity-name="moqui.ai.AiAgent" value-field="agent"/>
            <if condition="agent == null"><return error="true" message="Unknown agent ${agentId}"/></if>
            <if condition="agent.statusId != 'AI_AGENT_DRAFT'">
                <return error="true" message="Agent ${agentId} is not a draft (status ${agent.statusId})"/></if>
            <!-- re-check grants: every granted tool must still be exposable + active -->
            <entity-find entity-name="moqui.ai.AiAgentTool" list="grants">
                <econdition field-name="agentId"/></entity-find>
            <iterate list="grants" entry="g">
                <entity-find-one entity-name="moqui.ai.AiTool" value-field="tool">
                    <field-map field-name="toolId" from="g.toolId"/></entity-find-one>
                <if condition="tool == null || tool.exposable != 'Y' || tool.statusId != 'AI_TOOL_ACTIVE'">
                    <return error="true" message="Cannot activate: granted tool ${g.toolId} is not exposable/active"/></if>
            </iterate>
            <service-call name="update#moqui.ai.AiAgent" in-map="[agentId: agentId, statusId: 'AI_AGENT_ACTIVE']"/>
            <set field="statusId" value="AI_AGENT_ACTIVE"/>
        </actions>
    </service>

    <!-- Cleanup: drop a draft, its grants, AND the preview runs it spawned (with the steps / tool-calls /
         held approvals hanging off them). A draft is exercised only via preview#Agent, whose would-be
         mutating calls SUSPEND and write AI_TCREQ_PENDING rows; deleting those runs here is what keeps the
         abandoned approvals out of the operator queue (ToolCallRequestServices.get#PendingToolCallRequest). AiAgentRunStep
         has a real FK to AiAgentRun, so steps are deleted before the run. The screen "Discard draft" action. -->
    <service verb="discard" noun="Draft" authenticate="true">
        <in-parameters><parameter name="agentId" required="true"/></in-parameters>
        <actions>
            <entity-find-one entity-name="moqui.ai.AiAgent" value-field="agent"/>
            <if condition="agent == null"><return/></if>
            <if condition="agent.statusId != 'AI_AGENT_DRAFT'">
                <return error="true" message="Refusing to discard a non-draft agent ${agentId}"/></if>
            <script><![CDATA[
                for (run in ec.entity.find("moqui.ai.AiAgentRun").condition("agentId", agentId).list()) {
                    ec.entity.find("moqui.ai.AiToolCallRequest").condition("agentRunId", run.agentRunId).deleteAll()
                    ec.entity.find("moqui.ai.AiToolCall").condition("agentRunId", run.agentRunId).deleteAll()
                    ec.entity.find("moqui.ai.AiAgentRunStep").condition("agentRunId", run.agentRunId).deleteAll()
                }
                ec.entity.find("moqui.ai.AiAgentRun").condition("agentId", agentId).deleteAll()
            ]]></script>
            <entity-find entity-name="moqui.ai.AiAgentTool" list="grants"><econdition field-name="agentId"/></entity-find>
            <iterate list="grants" entry="g">
                <service-call name="delete#moqui.ai.AiAgentTool" in-map="[agentId: g.agentId, toolId: g.toolId]"/>
            </iterate>
            <service-call name="delete#moqui.ai.AiAgent" in-map="[agentId: agentId]"/>
        </actions>
    </service>
</services>
