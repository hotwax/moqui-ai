<?xml version="1.0" encoding="UTF-8"?>
<services xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/service-definition-3.xsd">

    <!-- Knowledge base CRUD and injection services.
         Bodies live as .md files in knowledge/ (component:// scheme). The entity is the queryable
         spine: lifecycle status, effective dates, and the contentLocation pointer. -->

    <service verb="store" noun="KnowledgeTopic" authenticate="true">
        <description>Create or update a knowledge topic. Validates that the .md body file exists before
        writing the row. Does NOT write the body — callers manage the file in git.</description>
        <in-parameters>
            <parameter name="topicId"/>
            <parameter name="topicName" required="true"/>
            <parameter name="description"/>
            <parameter name="contentLocation" required="true"/>
            <parameter name="fromDate" type="Timestamp"/>
            <parameter name="thruDate" type="Timestamp"/>
        </in-parameters>
        <out-parameters>
            <parameter name="topicId"/>
        </out-parameters>
        <actions>
            <!-- Security: the body is injected verbatim into the agent system prompt (authoritative) and
                 rendered on screen. ai.* services are ALL_USERS-reachable, so an unconstrained location would
                 be an arbitrary-file-read / SSRF / prompt-poisoning vector. Allowlist component://.../knowledge/*.md
                 only — blocks file:/http(s):/ftp: schemes and path traversal. -->
            <if condition="!contentLocation.startsWith('component://') || !contentLocation.contains('/knowledge/') || !contentLocation.endsWith('.md') || contentLocation.contains('..')">
                <return error="true"
                    message="contentLocation must be a component:// path under a knowledge/ directory ending in .md (e.g. component://moqui-ai/knowledge/oms-domain-primer.md). Got: ${contentLocation}"/>
            </if>
            <if condition="!ec.resource.getLocationReference(contentLocation).getExists()">
                <return error="true"
                    message="Knowledge body file not found: ${contentLocation}. Create the .md file under knowledge/ before registering the topic."/>
            </if>
            <if condition="!topicId">
                <set field="topicId" from="ec.entity.sequencedIdPrimary('moqui.ai.AiKnowledgeTopic', null, null)"/>
            </if>
            <entity-find-one entity-name="moqui.ai.AiKnowledgeTopic" value-field="existing" cache="false">
                <field-map field-name="topicId"/>
            </entity-find-one>
            <if condition="existing == null">
                <service-call name="create#moqui.ai.AiKnowledgeTopic"
                    in-map="[topicId: topicId, topicName: topicName, description: description,
                             contentLocation: contentLocation, fromDate: fromDate, thruDate: thruDate,
                             statusId: 'AI_KNOW_DRAFT', createdByUserId: ec.user.userId]"/>
                <else>
                    <script><![CDATA[
                        Map upd = [topicId: topicId, topicName: topicName, contentLocation: contentLocation]
                        if (description != null) upd.description = description
                        if (fromDate != null) upd.fromDate = fromDate
                        if (thruDate != null) upd.thruDate = thruDate
                        ec.service.sync().name("update#moqui.ai.AiKnowledgeTopic").parameters(upd).call()
                    ]]></script>
                </else>
            </if>
        </actions>
    </service>

    <service verb="approve" noun="KnowledgeTopic" authenticate="true">
        <description>Transition a knowledge topic from Draft to Approved so it is injected by the runner.</description>
        <in-parameters><parameter name="topicId" required="true"/></in-parameters>
        <actions>
            <entity-find-one entity-name="moqui.ai.AiKnowledgeTopic" value-field="topic"/>
            <if condition="topic == null"><return error="true" message="Topic ${topicId} not found"/></if>
            <service-call name="update#moqui.ai.AiKnowledgeTopic"
                in-map="[topicId: topicId, statusId: 'AI_KNOW_APPROVED']"/>
        </actions>
    </service>

    <service verb="archive" noun="KnowledgeTopic" authenticate="true">
        <description>Transition a knowledge topic to Archived so it is no longer injected.</description>
        <in-parameters><parameter name="topicId" required="true"/></in-parameters>
        <actions>
            <entity-find-one entity-name="moqui.ai.AiKnowledgeTopic" value-field="topic"/>
            <if condition="topic == null"><return error="true" message="Topic ${topicId} not found"/></if>
            <service-call name="update#moqui.ai.AiKnowledgeTopic"
                in-map="[topicId: topicId, statusId: 'AI_KNOW_ARCHIVED']"/>
        </actions>
    </service>

    <service verb="store" noun="AgentKnowledge" authenticate="true">
        <description>Grant a knowledge topic to an agent. DRAFT topics may be granted (they won't inject
        until Approved). ARCHIVED topics are rejected — restore to Approved first.</description>
        <in-parameters>
            <parameter name="agentId" required="true"/>
            <parameter name="topicId" required="true"/>
        </in-parameters>
        <actions>
            <entity-find-one entity-name="moqui.ai.AiKnowledgeTopic" value-field="topic"/>
            <if condition="topic == null">
                <return error="true" message="Topic ${topicId} not found"/>
            </if>
            <if condition="topic.statusId == 'AI_KNOW_ARCHIVED'">
                <return error="true" message="Cannot grant an archived topic (${topicId}). Restore it to Approved first."/>
            </if>
            <service-call name="store#moqui.ai.AiAgentKnowledge"
                in-map="[agentId: agentId, topicId: topicId]"/>
        </actions>
    </service>

    <service verb="revoke" noun="AgentKnowledge" authenticate="true">
        <description>Remove a knowledge topic grant from an agent.</description>
        <in-parameters>
            <parameter name="agentId" required="true"/>
            <parameter name="topicId" required="true"/>
        </in-parameters>
        <actions>
            <entity-find entity-name="moqui.ai.AiAgentKnowledge" list="grants">
                <econdition field-name="agentId"/>
                <econdition field-name="topicId"/>
            </entity-find>
            <iterate list="grants" entry="grant">
                <entity-delete value-field="grant"/>
            </iterate>
        </actions>
    </service>

    <service verb="find" noun="AgentKnowledge" authenticate="true">
        <description>Single source of truth: returns APPROVED, effective, granted knowledge topics
        for an agent with resolved body text. Skips topics whose body file is missing (logs warn).
        Sorted by topicName for deterministic injection order.</description>
        <in-parameters>
            <parameter name="agentId" required="true"/>
        </in-parameters>
        <out-parameters>
            <parameter name="topics" type="List"/>
        </out-parameters>
        <actions>
            <!-- One join: the agent's grants whose topic is APPROVED and currently effective, ordered for
                 deterministic injection. Only the body-file read needs a per-row step (it hits the resource
                 facade, not the DB), so it stays in the iterate; a missing file is skipped with a warning. -->
            <entity-find entity-name="moqui.ai.AiAgentKnowledgeTopicDetail" list="grants">
                <econdition field-name="agentId"/>
                <econdition field-name="statusId" value="AI_KNOW_APPROVED"/>
                <date-filter/>
                <order-by field-name="topicName"/>
                <select-field field-name="topicId"/>
                <select-field field-name="topicName"/>
                <select-field field-name="contentLocation"/>
            </entity-find>
            <set field="topics" from="[]"/>
            <iterate list="grants" entry="grant">
                <set field="content" from="ec.resource.getLocationText(grant.contentLocation, true)"/>
                <if condition="!content">
                    <log level="warn" message="Knowledge topic ${grant.topicId} body not found at ${grant.contentLocation} — skipping"/>
                    <continue/>
                </if>
                <script>topics.add([topicId: grant.topicId, topicName: grant.topicName, content: content])</script>
            </iterate>
        </actions>
    </service>

</services>
