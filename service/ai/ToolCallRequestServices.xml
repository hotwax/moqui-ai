<?xml version="1.0" encoding="UTF-8"?>
<services xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/service-definition-3.xsd">

    <service verb="approve" noun="ToolCallRequest" transaction="ignore" authenticate="true">
        <in-parameters><parameter name="toolCallRequestId" required="true"/><parameter name="decisionNote"/></in-parameters>
        <out-parameters><parameter name="agentRunId"/><parameter name="runStatusId"/></out-parameters>
        <actions>
            <service-call name="ai.ToolCallRequestServices.decide#ToolCallRequest" out-map="context"
                in-map="[toolCallRequestId: toolCallRequestId, statusId: 'AI_TCREQ_APPROVED', decisionNote: decisionNote]"/>
        </actions>
    </service>

    <service verb="reject" noun="ToolCallRequest" transaction="ignore" authenticate="true">
        <in-parameters><parameter name="toolCallRequestId" required="true"/><parameter name="decisionNote"/></in-parameters>
        <out-parameters><parameter name="agentRunId"/><parameter name="runStatusId"/></out-parameters>
        <actions>
            <service-call name="ai.ToolCallRequestServices.decide#ToolCallRequest" out-map="context"
                in-map="[toolCallRequestId: toolCallRequestId, statusId: 'AI_TCREQ_REJECTED', decisionNote: decisionNote]"/>
        </actions>
    </service>

    <!-- shared: record one decision; resume the run when no pending tool call requests remain for it -->
    <!-- transaction="ignore": decide# calls AgentRunner.resume(), whose LLM calls must hold NO enclosing
         tx (mirrors run#Agent). The AiToolCallRequest write here runs in its own tx via the entity-auto
         update# service-call; resume()'s writes/dispatch each manage their own tx (see AgentRunner). -->
    <service verb="decide" noun="ToolCallRequest" transaction="ignore" authenticate="true">
        <in-parameters>
            <parameter name="toolCallRequestId" required="true"/>
            <parameter name="statusId" required="true"/>
            <parameter name="decisionNote"/>
        </in-parameters>
        <out-parameters><parameter name="agentRunId"/><parameter name="runStatusId"/></out-parameters>
        <actions>
            <entity-find-one entity-name="moqui.ai.AiToolCallRequest" value-field="appr"/>
            <if condition="appr == null"><return error="true" message="Unknown toolCallRequestId ${toolCallRequestId}"/></if>
            <if condition="appr.statusId != 'AI_TCREQ_PENDING'"><return error="true" message="Tool call request already decided"/></if>
            <!-- Cross-user gate: a gated tool call is the conversation owner's decision to make. Without this any
                 authenticated user could approve/reject ANOTHER user's pending MUTATING tool call (then resume()
                 executes it). Resolve the owner from the run: the conversation owner for a conversation-backed
                 run, else the run initiator for a stateless run. Owner, or an operator (AI_OPERATOR / ADMIN),
                 only — fail-closed before the decision is recorded and resume() runs. -->
            <entity-find-one entity-name="moqui.ai.AiAgentRun" value-field="aprRun">
                <field-map field-name="agentRunId" from="appr.agentRunId"/></entity-find-one>
            <set field="ownerUserId" from="aprRun?.userId"/>
            <if condition="aprRun?.conversationId">
                <entity-find-one entity-name="moqui.ai.AiConversation" value-field="aprConv">
                    <field-map field-name="conversationId" from="aprRun.conversationId"/></entity-find-one>
                <set field="ownerUserId" from="aprConv?.userId ?: ownerUserId"/>
            </if>
            <if condition="ownerUserId != ec.user.userId &amp;&amp; !ec.user.isInGroup('AI_OPERATOR') &amp;&amp; !ec.user.isInGroup('ADMIN')">
                <log level="warn" message="AI authz: user ${ec.user.userId} denied deciding tool-call request ${toolCallRequestId} owned by ${ownerUserId} (not owner/AI_OPERATOR)."/>
                <return error="true" message="Not authorized to decide this tool-call request: it belongs to another user."/>
            </if>
            <service-call name="update#moqui.ai.AiToolCallRequest" in-map="[toolCallRequestId: toolCallRequestId, statusId: statusId,
                decisionNote: decisionNote, decidedByUserId: ec.user.userId, decidedDate: ec.user.nowTimestamp]"/>
            <set field="agentRunId" from="appr.agentRunId"/>
            <entity-find entity-name="moqui.ai.AiToolCallRequest" list="stillPending">
                <econdition field-name="agentRunId" from="agentRunId"/>
                <econdition field-name="statusId" value="AI_TCREQ_PENDING"/>
            </entity-find>
            <if condition="stillPending">
                <set field="runStatusId" value="AI_RUN_SUSPENDED"/>
                <else>
                    <script>
                        def r = new org.moqui.ai.AgentRunner(ec).resume(agentRunId)
                        runStatusId = r.statusId
                    </script>
                </else>
            </if>
        </actions>
    </service>

    <!-- Operator queue (rendered by screen/AiOps/Approvals.xml): with no agentRunId this returns the real
         pending tool call requests across all runs; with an agentRunId it scopes to that run. Composer preview runs
         (AiAgentRun.isPreview=Y) are always excluded — a preview SUSPENDS on would-be mutating calls only
         to SHOW them, then the run is abandoned, so those AI_TCREQ_PENDING rows are not real decisions and
         must not pollute the queue (discard#Draft deletes them outright). authenticate="true" only —
         per-approver permissions are deferred to Phase 5; until then any authenticated user can read the
         pending queue (incl. tool arguments). Do not "lock this down" piecemeal; it's gated by the Phase 5
         permissions work — the preview exclusion here is data hygiene, not a permission gate. -->
    <service verb="get" noun="PendingToolCallRequest" authenticate="true">
        <in-parameters><parameter name="agentRunId"/></in-parameters>
        <out-parameters><parameter name="approvalList" type="List"/></out-parameters>
        <actions>
            <!-- not-in on the preview run ids is null-safe (runs with a null isPreview are KEPT) and is
                 added only when the id list is non-empty (an empty not-in would otherwise match nothing). -->
            <script><![CDATA[
                def previewRunIds = ec.entity.find("moqui.ai.AiAgentRun").condition("isPreview", "Y")
                    .selectField("agentRunId").list().collect { it.agentRunId }
                def ef = ec.entity.find("moqui.ai.AiToolCallRequest")
                    .condition("statusId", "AI_TCREQ_PENDING").orderBy("requestedDate")
                if (agentRunId) ef.condition("agentRunId", agentRunId)
                if (previewRunIds) ef.condition("agentRunId", "not-in", previewRunIds)
                approvalList = ef.list()
            ]]></script>
        </actions>
    </service>
</services>
